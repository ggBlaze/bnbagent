# BNB Agent — user-specific runtime overrides (LOCAL, gitignored)
# --------------------------------------------------------------
# v2.1.8: this file is now SHIPPED PRE-POPULATED with mainnet defaults.
# A fresh install lands on BSC mainnet (chain 56, real RPCs, tier=binance).
# Override any field below — boot() deep-merges local.yaml over config.yaml.
#
# To switch to replay/testnet for safe dry-runs, set:
#     mode: replay
#     chain_id: 97
#     rpcs: [http://localhost:8545]
#
# NEVER commit this file. It is .gitignored for a reason.

mode: mainnet
chain_id: 56
rpcs:
  - https://bsc-dataseed.binance.org
  - https://bsc-dataseed1.defibit.io
  - https://bsc-dataseed1.ninicoin.io

data_source:
  # x402 | cmc_pro | binance | mock
  # binance is free and needs no key — recommended default.
  # x402 pays CMC per-call in USDC on Base (no key, micro-budget).
  # cmc_pro is paid (unlimited calls).
  # mock reads from data/cmc_mock.json (offline testing).
  tier: binance
  cmc_api_key: ""
  base_rpcs:
    - https://mainnet.base.org
    - https://base.publicnode.com
    - https://1rpc.io/base
  daily_cap_usdc: 10.0
  # base_address is auto-populated by boot.py from your wallet.
  # Override here only if you want x402 to fund a different address.
  base_address: ""

# Perps venue list (real execution requires venue API keys + integration
# per venue; see docs/venue_implement_me.md for the per-venue checklist).
# The current scaffold supports paper mode for all venues. To enable
# real execution for a specific venue, set perps.<venue>.api_key below.
perps:
  candidates:
    - aster
    - killex
    - apollox
    - mux
  # aster:
  #   api_key: ""
  #   api_secret: ""
  # killex: ...