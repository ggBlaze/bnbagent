# BNB Agent — environment configuration
# Copy to .env and fill in. NEVER commit .env.

# --- Trust Wallet (TWAK) ---
TWAK_KEYSTORE=~/.twak/wallet.json
TWAK_PWD=                            # user types this once at session start
TWAK_CHAIN=bsc

# --- CoinMarketCap ---
# x402 (preferred): no API key, pay per request
CMC_X402_BASE=https://api.coinmarketcap.com/agent-hub
CMC_API_BASE=https://pro-api.coinmarketcap.com
CMC_API_KEY=                          # only needed for non-x402 fallback

# x402 Base RPCs (comma-separated, used for USDC balance polling)
BASE_RPCS=https://mainnet.base.org,https://base.publicnode.com,https://1rpc.io/base

# --- bnbagent-sdk / BNB Chain ---
BSC_RPCS=                             # comma-separated, rotate
BNB_SDK_RPC=https://bsc-dataseed.binance.org
BNB_SDK_CHAIN_ID=56

# --- IPFS (local) ---
IPFS_API=/ip4/127.0.0.1/tcp/5001

# --- Agent wallet (auto-set by TWAK init) ---
AGENT_ADDRESS=

# --- Mode ---
BNBAGENT_MODE=testnet                # testnet | mainnet | replay
BNBAGENT_LOG_LEVEL=INFO
BNBAGENT_DASHBOARD_PORT=8000

# --- LLM provider keys (AI Agent Team) ---
# All optional. The agent runs as a deterministic bot if none are set.
# Add ONE of these and `agents/providers.yaml` will pick it up.
OPENROUTER_API_KEY=                    # easiest: covers all 4 agent roles
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OAI_BASE=                              # for OAI-compatible endpoints (Mistral, Together, etc)
# OAI_KEY=
# OAI_MODEL=
# LOCAL_LLM_BASE=http://127.0.0.1:8080  # for llama.cpp / ollama

# --- Notification Skills (optional) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# WARPCAST_KEY=
# WEBHOOK_URL=https://your-zapier-or-discord-webhook.example/hook

# --- MCP server (optional) ---
# BNBAGENT_MCP_HOST=0.0.0.0
# BNBAGENT_MCP_PORT=8765

# --- Contest / safety locks (all default OFF in production) ---
# Token Module launches are HARD-LOCKED until 2026-07-07 00:00 UTC per
# BNB HACK 2026 rules. After that date, set this to "true" to opt in
# to real deploys. Default: false (the code refuses regardless of date).
# BNBAGENT_ALLOW_TOKEN_DEPLOY=false

# Mnemonic export route is OFF by default. Setting this to "true"
# allows the /api/wallet/export-mnemonic endpoint to return the seed
# phrase (still requires admin cookie + wallet password). Default:
# false. A judge who gets the admin password still cannot drain the
# wallet unless they ALSO have SSH access to the host.
# BNBAGENT_ALLOW_WALLET_EXPORT=false

# Wallet import route is OFF by default. Setting this to "true"
# allows /api/setup/wallet/import to replace the keystore. Default:
# false. Same defense-in-depth rationale as the export.
# BNBAGENT_ALLOW_WALLET_IMPORT=false

