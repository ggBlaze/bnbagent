data/parquet/*
data/recordings/*
data/jobs-*.json
data/window-*-summary.json
# v2.0.5.1: data/reports/ is committed so the meta-test has a stable
# JSON target across machines. Re-generate locally with
# `python -m scripts.run_both_regimes` and only commit if you intend
# to update the demo-script table to match.
# The HTMLs are render-only (a view of the committed JSON) — regenerated
# by the same script. Don't commit them; they cause churn and merge noise.
data/reports/*.html
!data/parquet/.gitkeep
!data/recordings/.gitkeep
.coverage
htmlcov/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.DS_Store
node_modules/
dist/
build/
logs/

