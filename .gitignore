__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.env
.env.local
*.log
.parquet/
data/parquet/*
data/recordings/*
data/jobs-*.json
data/window-*-summary.json
# v2.1.4: competition registration cache (contains agent address +
# tx hash). scripts/competition_register.py writes this; the
# dashboard /api/competition/register/status reads it. Outside
# git so a fresh clone never has stale registration data.
data/competition_register.json
# v2.0.5.1: data/reports/ is committed so the meta-test has a stable
# JSON target across machines. Re-generate locally with
# `python -m scripts.run_both_regimes` and only commit if you intend
# to update the demo-script table to match.
# The HTMLs are render-only (a view of the committed JSON) — regenerated
# by the same script. Don't commit them; they cause churn and merge noise.
data/reports/*.html
!data/parquet/.gitkeep
!data/recordings/.gitkeep
.coverage
htmlcov/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.DS_Store
node_modules/
dist/
build/
logs/

# Agent identity (contains wallet + ERC-8004 token)
.bnbagent/

# User-specific runtime overrides (Setup wizard writes here, never tracked).
# The shipped defaults live in config/config.yaml; this file is the shadow
# layer. See core/config_paths.py for the merge semantics.
config/local.yaml

# Operator-signed User Policy. The shipped example lives in
# config/policy.yaml.example (a template with __SIG__/__EVAL__ placeholders
# that install.sh + policy_sign --dev populate with a fresh ephemeral
# signature). The real config/policy.yaml is regenerated by `bash install.sh`
# on first run and overwritten by the Setup wizard's "Sign Policy" step
# when the operator signs with their TWAK keystore. Tracking the real file
# would let a stale signature land in git (the shipped one was expired
# AND didn't recover to evaluator_address — see v2.1.2 CHANGELOG).
config/policy.yaml

# Token Module config (agents/token_module.py::update_config writes here
# when the dashboard's Token pane is used). The runtime creates the file
# on first edit; the example is the DEFAULT_CONFIG baked into the module.
agents/token_module.yaml

# TWAK keystore. Lives at ~/.twak/wallet.json — outside the repo by default,
# and AES-256-GCM-encrypted with the operator's password, but gitignore
# for defense in depth (in case a future install path puts it inside the
# repo).
.twak/

# IDE
.vscode/
.idea/
*.swp
*.swo
