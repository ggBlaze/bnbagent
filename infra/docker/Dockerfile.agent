FROM python:3.12-slim

WORKDIR /app

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl gcc git && \
    rm -rf /var/lib/apt/lists/*

# Python deps
COPY pyproject.toml ./
RUN pip install --no-cache-dir \
    "web3>=7.0" "eth-account>=0.13" "pydantic>=2.0" \
    "fastapi>=0.110" "uvicorn[standard]>=0.27" "httpx>=0.27" \
    "pyyaml>=6.0" "jsonschema>=4.21" "numpy>=1.26" "pandas>=2.1" \
    "python-dotenv>=1.0" "rich>=13.7" "pytest>=8.0" "pytest-asyncio>=0.23"

# App
COPY . .

# Default: replay
CMD ["python", "-m", "backtest.replay", "--report", "/app/data/reports/replay.html"]
